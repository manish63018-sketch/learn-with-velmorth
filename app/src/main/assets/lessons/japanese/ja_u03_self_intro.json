      "grammar_point": {
        "grammar_id": "ja_gram_nationality_age",
        "title": "Stating Origin & Age",
        "structure": "[Country] ＋ 人 です / [Age Number] ＋ 歳 です",
        "romaji_structure": "[Country] + jin desu / [Age Number] + sai desu",
        "short_explanation_en": "Attach 'jin' to a country for nationality. Attach 'sai' to a number for age.",
        "short_explanation_hi": "राष्ट्रीयता के लिए देश के नाम के पीछे 'jin' जोड़ें। आयु के लिए संख्या के पीछे 'sai' जोड़ें।",
        "focus_examples": [
