          "part_of_speech": "pronoun",
          "topic_tags": [
            "self"
          ],
          "frequency": 5,
          "notes": "Formal/standard word for both genders."
        },
        {
          "vocab_id": "ja_vocab_namae",
          "kanji": "名前",
          "kana": "なまえ",
          "romaji": "namae",
          "meaning_en": "name",
          "meaning_hi": "नाम",
          "part_of_speech": "noun",
          "topic_tags": [
            "self"
          ],
          "frequency": 5,
          "notes": "Used standardly."
        }
      ],
      "grammar_point": {
        "grammar_id": "ja_gram_intro_name",
        "title": "My name is...",
        "structure": "私は [Name] です",
        "romaji_structure": "Watashi wa [Name] desu",
        "short_explanation_en": "This means 'I am [Name]'. It is the easiest and most direct way to introduce yourself.",
        "short_explanation_hi": "इसका अर्थ है 'मैं [Name] हूँ'। अपना परिचय देने का यह सबसे आसान तरीका है।",
        "focus_examples": [
          "私はラヴィです。"
        ],
        "focus_examples_romaji": [
          "Watashi wa Ravii desu."
        ],
        "notes": "Replace 'Ravii' with your actual name."
      },
      "pronunciation": {
        "tips_en": [
          "The 'wa' particle should be pronounced flatly, with no accent."
        ],
        "tips_hi": [
          "'wa' कण का उच्चारण बिना किसी विशेष स्वर-भार के सपाट रूप से करें।"
        ],
        "audio_ids": []
      },
      "examples": [
        {
          "example_id": "ja_u03_l01_ex_sentence_1",
          "japanese": "はじめまして、私はラヴィです。",
          "romaji": "Hajimemashite, watashi wa Ravii desu.",
          "translation_en": "Nice to meet you, I am Ravi.",
          "translation_hi": "आपसे मिलकर अच्छा लगा, मैं रवि हूँ।",
          "highlight_vocab_ids": [
            "ja_vocab_watashi"
          ],
          "context_note": "A perfect opening line when meeting someone."
        }
      ],
      "review_words": [
        "ja_vocab_watashi"
      ],
