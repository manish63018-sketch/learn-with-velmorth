<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — NoActionBar since we use Compose -->
    <style name="Theme.LearnWithVelmorth" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Forest green status bar -->
        <item name="android:statusBarColor">#1B4332</item>
        <item name="android:navigationBarColor">#FAFAF5</item>
        <item name="android:windowBackground">#F1E8D0</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.LearnWithVelmorth.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1B4332</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.LearnWithVelmorth</item>
    </style>
</resources>