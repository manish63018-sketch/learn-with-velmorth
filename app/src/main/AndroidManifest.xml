<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- POST_NOTIFICATIONS required for Android 13+ (API 33) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Camera permission -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Microphone permission -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Storage permissions -->
    <!-- For Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- For Android 12 and below (API 32 and below) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:name=".VelmorthApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Velmorth">

        <!-- Resolve conflict between AdMob and Firebase Analytics AD_SERVICES_CONFIG resource -->
        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />

        <!-- AdMob App ID (production ID) -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-8150181705727957~6107807020" />

        <!-- ── Splash (Launcher entry-point) ── -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Velmorth.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Onboarding flow ── -->
        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />

        <!-- ── Authentication ── -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />
        <activity
            android:name=".ui.auth.SignupActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />

        <!-- ── Main Dashboard ── -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />

        <!-- ── Lesson Player ── -->
        <activity
            android:name=".ui.lessons.LessonPlayerActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />

        <!-- ── Edit Profile ── -->
        <activity
            android:name=".ui.profile.EditProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth"
            android:launchMode="singleTop" />

        <!-- ── Settings ── -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />

        <!-- ── Premium Paywall ── -->
        <activity
            android:name=".ui.premium.PremiumActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth.Premium" />

        <!-- ── Permissions System ── -->
        <activity
            android:name=".ui.permissions.PermissionsActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />

        <!-- ── Legal Screens & support ── -->
        <activity
            android:name=".ui.legal.PrivacyPolicyActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />
        <activity
            android:name=".ui.legal.TermsConditionsActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />
        <activity
            android:name=".ui.legal.AboutAppActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />
        <activity
            android:name=".ui.legal.ContactSupportActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />
        <activity
            android:name=".ui.legal.LicensesActivity"
            android:exported="false"
            android:theme="@style/Theme.Velmorth" />

        <!-- ── FileProvider for camera capture (Android 7+) ── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
