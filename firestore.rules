rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ─────────────────────────────────────────────────────
    // Users can only read/write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Sub-collection: progress (user-scoped lesson progress)
      match /progress/{lessonId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Sub-collection: srs (spaced-repetition cards)
      match /srs/{cardId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Settings collection ───────────────────────────────────────────────────
    // Users can only read/write their own settings document.
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Progress collection (top-level) ───────────────────────────────────────
    // Document ID format: {uid}_{lessonId}
    // Only the owning user can read/write their progress entries.
    match /progress/{progressId} {
      allow read, write: if request.auth != null
        && progressId.matches(request.auth.uid + '_.*');
    }

    // ── Lessons collection ────────────────────────────────────────────────────
    // All authenticated users can READ lesson metadata.
    // Only server-side (admin SDK) or the app's seeding logic can WRITE.
    // Because the app uses SetOptions.merge() client-side seeding, we allow
    // authenticated writes here for MVP. Lock down with Admin SDK in production.
    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;  // Tighten to admin-only post-launch
    }

    // ── Deny all other access ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
